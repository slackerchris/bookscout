# -----------------------------------------------------------------------
# BookScout environment variable reference
# Copy to .env (same directory as docker-compose.yml) and fill in values.
# These override matching keys in config.yaml when both are present.
# Only the vars you actually need are required — everything else is optional.
#
# ⚠ Value formatting rules (docker compose .env):
#   - A `#` in an unquoted value starts a comment — EVERYTHING AFTER IT IS
#     SILENTLY DROPPED. Wrap values containing #, spaces, or $ in single
#     quotes:  TORRENT_PASSWORD='p@ss#word'
#   - A literal `$` in an unquoted value must be doubled: $$
#   - POSTGRES_PASSWORD is spliced into a connection URL — keep it to
#     letters and digits only (make it LONG instead of weird). Characters
#     like @ : / # ? % will corrupt the URL and quoting cannot save you.
#   - Portainer stacks do NOT read this file — enter the variables in the
#     stack's "Environment variables" section instead.
# -----------------------------------------------------------------------

# --- Required: infrastructure -------------------------------------------

# Password for the bundled Postgres (compose wires the connection string).
# Letters + digits only — see formatting rules above.
POSTGRES_PASSWORD=change-me-long-alphanumeric

# Only needed when NOT using the bundled compose services:
# DATABASE_URL=postgresql+asyncpg://bookscout:password@postgres/bookscout
# REDIS_URL=redis://redis:6379

# --- Audiobookshelf (ownership sync) ------------------------------------

# Base URL of your ABS instance (no trailing slash)
AUDIOBOOKSHELF_URL=http://audiobookshelf:13378

# API token — Settings > Users > (your user) > API Token in ABS
AUDIOBOOKSHELF_TOKEN=your_abs_api_token_here

# --- Indexers -------------------------------------------------------------

PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=your_prowlarr_api_key_here

# JACKETT_URL=http://jackett:9117
# JACKETT_API_KEY=your_jackett_api_key_here

# --- Download client ------------------------------------------------------

# "qbittorrent" | "transmission" | "sabnzbd"
DOWNLOAD_PREFERRED=qbittorrent

TORRENT_URL=http://qbittorrent:8080
TORRENT_USERNAME=admin
# Single-quote if it contains special characters (see rules above).
# May be left blank if BookScout's IP is on qBittorrent's auth-bypass
# whitelist (Options → Web UI → "Bypass authentication for clients in
# whitelisted IP subnets" → your-bookscout-ip/32).
TORRENT_PASSWORD=''
# qBittorrent category — must match the category your indexer sends with;
# the auto-import poller only looks at completed torrents in this category.
TORRENT_CATEGORY=audiobooks
# TORRENT_SAVE_PATH=

# SABNZBD_URL=
# SABNZBD_API_KEY=
# SABNZBD_CATEGORY=

# --- Post-processing / auto-import ---------------------------------------

# "bookscout" = BookScout extracts archives and organises completed
#               downloads into <library_root>/<Author>/<Series>/<Title>/,
#               and the qBittorrent auto-import poller activates.
# "client"    = your download client is responsible (default).
POSTPROCESS_MODE=bookscout
# Path AS SEEN INSIDE THE CONTAINER (i.e. the right-hand side of the
# compose volume mount, e.g. /media/audiobooks:/audiobooks -> /audiobooks)
POSTPROCESS_LIBRARY_ROOT=/audiobooks

# --- Scanning -------------------------------------------------------------

# ISO 639-1 code, or "all" to accept every language
SCAN_LANGUAGE_FILTER=en

# --- Optional: external book APIs ----------------------------------------

# Google Books — free key, raises rate limit from ~100 to 1000 req/day
# https://console.cloud.google.com/  → Enable "Books API" → create API key
GOOGLE_BOOKS_API_KEY=

# ISBNdb — paid ($10-50/month), greatly improves ISBN coverage
# https://isbndb.com/isbn-database
ISBNDB_API_KEY=

# --- Optional: application ------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# Bearer-token auth: when set to anything non-default, every API request
# must send "Authorization: Bearer <SECRET_KEY>".
# NOTE: bookscout-ui does not send bearer tokens yet — leave unset if you
# use the web UI, and restrict access at the network/proxy layer instead.
# SECRET_KEY=

# Override the port uvicorn listens on (default: 8765)
# PORT=8765

# Path to config.yaml if not using the default /data/config.yaml
# BOOKSCOUT_CONFIG=/data/config.yaml
