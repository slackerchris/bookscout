# -----------------------------------------------------------------------
# BookScout environment variable reference
# Copy to .env and fill in your values.
# These override matching keys in config.yaml when both are present.
# Only the vars you actually need are required — everything else is optional.
# -----------------------------------------------------------------------

# --- Required: infrastructure -------------------------------------------

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://bookscout:bookscout@db/bookscout

# Redis connection string
REDIS_URL=redis://redis:6379

# --- Required: Audiobookshelf -------------------------------------------

# Base URL of your ABS instance (no trailing slash)
AUDIOBOOKSHELF_URL=http://audiobookshelf:13378

# API token — Settings > Users > (your user) > API Token in ABS
AUDIOBOOKSHELF_TOKEN=your_abs_api_token_here

# --- Optional: Prowlarr -------------------------------------------------

PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=your_prowlarr_api_key_here

# --- Optional: Jackett --------------------------------------------------

# JACKETT_URL=http://jackett:9117
# JACKETT_API_KEY=your_jackett_api_key_here

# --- Optional: external book APIs ---------------------------------------

# Google Books — free key, raises rate limit from ~100 to 1000 req/day
# https://console.cloud.google.com/  → Enable "Books API" → create API key
GOOGLE_BOOKS_API_KEY=

# ISBNdb — paid ($10-50/month), greatly improves ISBN coverage
# https://isbndb.com/isbn-database
ISBNDB_API_KEY=

# --- Optional: application ----------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
# Set to DEBUG for verbose per-request logging, useful for troubleshooting
LOG_LEVEL=INFO

# Change this in production to a random secret (used for session signing)
SECRET_KEY=bookscout-secret-key-change-in-production

# Override the port uvicorn listens on (default: 8000)
# PORT=8000

# Path to config.yaml if not using the default /data/config.yaml
# BOOKSCOUT_CONFIG=/data/config.yaml
